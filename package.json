{
	"name": "unplugin-inline-functions",
	"version": "0.3.10",
	"description": "Universal plugin to inline functions in your code. Works with Vite, Rollup, Webpack, esbuild, Rolldown, and more.",
	"license": "ISC",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.ts",
				"require": "./dist/index.d.cts"
			},
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest"
	},
	"devDependencies": {
		"@babel/generator": "^7.29.1",
		"@babel/parser": "^7.29.2",
		"@babel/traverse": "^7.29.0",
		"@babel/types": "^7.29.0",
		"@types/babel__generator": "^7.27.0",
		"@types/babel__traverse": "^7.28.0",
		"@types/node": "latest",
		"chalk": "^5.6.2",
		"esbuild": "^0.27.4",
		"eslint": "^10.1.0",
		"rollup": "^4.60.1",
		"rollup-plugin-esbuild": "^6.2.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"peerDependencies": {
		"@babel/parser": "^7.26.3",
		"@babel/traverse": "^7.26.4",
		"@babel/types": "^7.26.3"
	},
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"fast-glob": "^3.3.3",
		"unplugin": "^3.0.0",
		"webpack": "^5.105.4"
	},
	"pnpm": {
		"overrides": {
			"rollup": "^4.52.3",
			"esbuild": "^0.25.10"
		},
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
